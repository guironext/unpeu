// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// User roles: VISITOR (buyer), COMMERCIAL (sales), DEALER (sells products), ADMIN
enum UserRole {
  VISITOR
  COMMERCIAL
  DEALER
  SHOPPER
  ADMIN
}

// User profile synced from Clerk (via webhook)
model User {
  id            String    @id @default(cuid())
  clerkId       String    @unique
  email         String
  firstName     String?
  lastName      String?
  contact       String?
  role          UserRole  @default(VISITOR)
  invitedById   String?
  invitedBy     User?     @relation("Invitations", fields: [invitedById], references: [id])
  invitedUsers  User[]    @relation("Invitations")
  invitationLinks InvitationLink[]
  orders        Order[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([clerkId])
  @@index([role])
}

// Invitation links created by commercial users for visitors
model InvitationLink {
  id          String   @id @default(cuid())
  code        String   @unique
  token       String   @unique
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  sentToEmail String?  // Optional: email of recipient when invitation was sent
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([code])
  @@index([token])
}

// Product categories (Jumia-style)
model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  imageUrl  String?
  products  Product[]
  createdAt DateTime  @default(now())
}

// Products
model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  caratéristique_technique String?
  dimensions_et_poids String?
  weight String?
  couleur String?
  reduction_percentage Int?
  material String?
  style String?
  motif String?
  thème String?
  saison String?
  price       Decimal
  imageUrl    String?
  stock       Int         @default(0)
  categories  Category[]
  rubriques   Rubrique[]
  promotions  Promotion[]
  orderItems  OrderItem[]
  caracteristiqueTechnique CaracteristiqueTechnique[]
  garanties Garantie[]
  fichesTechniques FicheTechnique[]
  descriptionsTechniques DescriptionTechnique[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([slug])
}

model CaracteristiqueTechnique {
  id        String    @id @default(cuid())
  name      String
  title     String
  description String?
  imageUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([title])
  @@index([description])
  @@index([imageUrl])
  products  Product[]
}

model Garantie {
  id        String    @id @default(cuid())
  description      String
  title     String
  duree_garantie Int?
  products  Product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FicheTechnique {
  id        String    @id @default(cuid())
  name      String
  title     String
  description String?
  imageUrl String?
  products  Product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
} 

model DescriptionTechnique {
  id        String    @id @default(cuid())
  name      String
  title     String
  description String?
  imageUrl String?
  products  Product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


// Rubrique
model Rubrique {
  id        String    @id @default(cuid())
  name      String
  products  Product[]
}

model Promotion {
  id        String    @id @default(cuid())
  name      String
  taux      Int
  products  Product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taux])
}

// Order status
enum OrderStatus {
  PENDING
  PAYMENT_PENDING
  PAYMENT_FAILED
  PAYMENT_SUCCESS
  PAYMENT_EXPIRED
  PAYMENT_CANCELLED
  PAYMENT_REFUNDED
  PAYMENT_PARTIALLY_REFUNDED
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// Orders
model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  status        OrderStatus @default(PENDING)
  totalAmount   Decimal     @db.Decimal(10, 2)
  shippingAddress String?
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  payment Payment[]

  @@index([userId])
  @@index([orderNumber])
}

// Order line items
model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

enum PaymentMethod {
  CASH
  ORANGE_MONEY
  MOOV_MONEY
  MTN_MONEY
  CARD
}

model Payment {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  amount    Decimal
  amountPaid Decimal
  amountDue Decimal
  paymentMethod PaymentMethod


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
}